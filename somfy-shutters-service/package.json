{
  "name": "somfy-shutters-service",
  "version": "1.0.0",
  "description": "Internal Authentication Service",
  "license": "ISC",
  "author": "",
  "main": "main.js",
  "scripts": {
    "build": "tsc && cp package*.json .env build/ && cd build && npm install --omit=dev",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "bundle": "esbuild src/index.ts --bundle --outfile=bundle/somfy-shutters-service.js --platform=node",
    "start": "ts-node-dev ./src/index.ts",
    "startBundle": "ts-node-dev ./bundle/somfy-shutters-service.js",
    "test": "jest",
    "typeorm": "ts-node ./node_modules/typeorm/cli",
    "typeorm:run-migrations": "npm run typeorm migration:run -- -d ./src/typeorm.config.ts",
    "typeorm:generate-migration": "npm run typeorm -- -d ./src/typeorm.config.ts migration:generate ./src/migrations/$npm_config_name",
    "typeorm:create-migration": "npm run typeorm -- -d ./src/typeorm.config.ts migration:create ./src/migrations/$npm_config_name",
    "typeorm:revert-migration": "npm run typeorm -- -d ./src/typeorm.config.ts migration:revert"
  },
  "dependencies": {
    "@inversifyjs/binding-decorators": "^3.0.0",
    "@inversifyjs/http-core": "^5.2.0",
    "@inversifyjs/http-express": "^5.2.0",
    "body-parser": "^2.2.2",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "inversify": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/parser": "^8.58.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
