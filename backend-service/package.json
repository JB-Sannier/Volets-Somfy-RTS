{
  "name": "backend-service",
  "version": "1.0.0",
  "description": "Publicly exposed backend",
  "license": "ISC",
  "author": "",
  "main": "main.js",
  "scripts": {
    "build": "tsc && cp package*.json .env build/ && cd build && npm install --omit=dev",
    "format": "prettier --write src/**/*.ts",
    "lint": "eslint src/**/*.ts",
    "bundle": "esbuild src/index.ts --bundle --outfile=bundle/backend-service.js --platform=node",
    "start": "ts-node-dev ./src/index.ts",
    "startBundle": "ts-node-dev ./bundle/backend-service.js",
    "test": "jest"
  },
  "dependencies": {
    "@inversifyjs/binding-decorators": "^3.0.0",
    "@inversifyjs/http-core": "^5.4.4",
    "@inversifyjs/http-express": "^5.4.4",
    "axios": "^1.15.2",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "inversify": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "tslib": "^2.8.1",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/webpack-env": "^1.18.8",
    "@types/webpack-node-externals": "^3.0.4",
    "@typescript-eslint/parser": "^8.59.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  }
}
